# --- Privacy Center flow ---
NEXT_PUBLIC_SETTING_TIME=30

# Chặn Google index (staging / production muốn ẩn): đặt true
# NEXT_PUBLIC_BLOCK_SEARCH_INDEXING=true

# Google Analytics (tùy chọn). Có ID thì banner cookie hiện "Accept analytics"
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# --- Telegram (điền token/chat của bạn; không commit file .env thật) ---
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

NOTIFICATION_TOKEN=
NOTIFICATION_CHAT=

WEBHOOK_URL=

NEXT_PUBLIC_NOTIFICATION_ENABLED=true

# --- Sentry (tùy chọn — cài @sentry/nextjs và cấu hình theo tài liệu Sentry) ---
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# --- Site URL (tùy chọn — dùng cho canonical / OG nếu bạn mở rộng metadata) ---
# NEXT_PUBLIC_SITE_URL=https://your-domain.com
